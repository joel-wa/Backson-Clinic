      "format": "date-time"
    },
    "client_name": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "consulting_area": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "urgency": {
